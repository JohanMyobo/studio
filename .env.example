# Base de données PostgreSQL (Supabase)
# Settings > Database > Connection string > URI
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[REF].supabase.co:5432/postgres"

# Auth — accès privé à l'app
# AUTH_SECRET : une chaîne aléatoire longue (ex: openssl rand -hex 32)
AUTH_SECRET="change-me-with-a-random-string"

# AUTH_PASSWORD : le mot de passe que tu taperas sur la page /login
AUTH_PASSWORD="ton-mot-de-passe-ici"

# Anthropic (pour la couche IA, plus tard)
ANTHROPIC_API_KEY=sk-ant-...
